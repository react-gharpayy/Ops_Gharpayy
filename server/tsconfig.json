{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "zod": ["./node_modules/zod"],
      "zod/*": ["./node_modules/zod/*"],
      "@contracts/*": ["../src/contracts/*"]
    }
  },
  "include": ["src/**/*", "../src/contracts/**/*"]
}
