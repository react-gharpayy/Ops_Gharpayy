# Copy this file to .env and fill in. NEVER commit .env.

# --- MongoDB Atlas (Mumbai region, ap-south-1) ---
MONGO_URL=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=gharpayy

# --- Redis (local for dev, ElastiCache or managed Redis in prod) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Auth.js compatible JWT) ---
# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-48-byte-random-base64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Server ---
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# --- CORS — comma-separated list of allowed origins ---
CORS_ORIGINS=http://localhost:5173,https://your-frontend.lovable.app,https://crm.gharpayy.com

# --- Tenant — single-tenant for now ---
DEFAULT_TENANT=gharpayy

# --- Logging ---
LOG_LEVEL=info
